# SETKA Project .gitignore

# Claude Code working directory
# Игнорируем всё, кроме того, что должно жить в репо вместе с проектом:
# - .claude/commands/  — slash-команды (/start, /reliz, /check, /sql, /celery, /logs, /finish)
# - .claude/agents/    — кастомные субагенты (если появятся)
# Остальное (worktrees, локальная сессия, settings.local.json конкретного компа) — локально.
.claude/*
!.claude/commands/
!.claude/agents/

# Secure configuration files
config/config_secure.py
config/config.secure.py
config/*.env
config/.env*
*.key
*.pem

# Secrets backup file
SECRETS_BACKUP.txt
SECRETS*.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/

# Logs
logs/
*.log

# Database
*.db
*.sqlite
*.sqlite3

# Backup files
backup/*.sql
backup/*.sql.gz
backup/*.dump
backup/*.tar.gz

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
temp/

# Node modules (if any)
node_modules/

# Cache
.cache/
*.cache

# Old project analysis
old_project_analysis/postopus/

# AI Model weights (if stored locally)
models/*.bin
models/*.safetensors

