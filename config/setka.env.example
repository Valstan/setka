# SETKA example environment (DO NOT put real secrets in git)
#
# Copy to a secure location (e.g. /etc/setka/setka.env) and load via your process manager (systemd, supervisor, etc.)

# Required
DATABASE_URL=postgresql+asyncpg://setka_user:CHANGE_ME@localhost:5432/setka
REDIS_URL=redis://localhost:6379/0

# Optional: VK tokens (any number). Names are mapped from suffix: VK_TOKEN_VALSTAN -> "VALSTAN"
VK_TOKEN_VALSTAN=vk1.a.CHANGE_ME
VK_TOKEN_VITA=vk1.a.CHANGE_ME

# Optional: Telegram
TELEGRAM_TOKEN_VALSTANBOT=CHANGE_ME
TELEGRAM_ALERT_CHAT_ID=CHANGE_ME

# Optional: server info (used for building dashboard URLs in notifications)
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Optional: DB pool (Celery + uvicorn each have a pool; keep totals under Postgres max_connections)
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=5
# DB_POOL_RECYCLE=3600

# Сетевой хаб copy/setka (расписание :07 и :37): стена по умолчанию vk.com/copy_by_setka (-167381590)
# Режим: если в тексте поста есть слово «репост» — wall.repost вложенного поста; иначе копия текста+вложений.
# COPY_SETKA_SOURCE_GROUP_ID=-167381590
# COPY_SETKA_DISABLED=0
# COPY_SETKA_REPOST_MESSAGE=
# COPY_SETKA_MAX_POST_AGE_HOURS=48
# COPY_SETKA_TARGET_REGION_CODES=pizhanka,ur

# Optional: AI
GROQ_API_KEY=CHANGE_ME


