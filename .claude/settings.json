{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git status:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git push origin:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(pre-commit run:*)",
      "Bash(pytest:*)",
      "Bash(./venv/bin/python -m pytest:*)",
      "Bash(ssh setka:*)",
      "PowerShell(git status:*)",
      "PowerShell(git fetch:*)",
      "PowerShell(git pull --ff-only:*)",
      "PowerShell(git log:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git show:*)",
      "PowerShell(git add:*)",
      "PowerShell(git restore:*)",
      "PowerShell(git stash:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git checkout:*)",
      "PowerShell(git switch:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git merge:*)",
      "PowerShell(git rebase:*)",
      "PowerShell(git push origin:*)",
      "PowerShell(gh pr create:*)",
      "PowerShell(gh pr merge:*)",
      "PowerShell(gh pr view:*)",
      "PowerShell(gh pr list:*)",
      "PowerShell(gh pr diff:*)",
      "PowerShell(gh pr checks:*)",
      "PowerShell(gh run list:*)",
      "PowerShell(gh run view:*)",
      "PowerShell(pre-commit run:*)",
      "PowerShell(pytest:*)",
      "PowerShell(.\\venv\\Scripts\\python.exe -m pytest:*)",
      "PowerShell(py -3.11 -m pytest:*)",
      "PowerShell(py -3.12 -m pytest:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:master)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git push -f:*)",
      "PowerShell(git push origin main)",
      "PowerShell(git push origin master)",
      "PowerShell(git reset --hard:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/git_sync_check.sh\" --warn"
          }
        ]
      }
    ]
  }
}
