# SETKA Environment Configuration
# Скопируйте этот файл в .env и заполните реальными значениями
# НЕ коммитьте реальный .env в git!

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql+asyncpg://setka_user:YOUR_PASSWORD@localhost:5432/setka
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
SQLALCHEMY_ECHO=0

# ============================================================================
# Redis (Celery broker + caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# VK API
# ============================================================================
VK_API_VERSION=5.131

# VK токены (префикс VK_TOKEN_ автоматически собирает все токены)
VK_TOKEN_VALSTAN=your_token_here
VK_TOKEN_VITA=your_token_here

# ============================================================================
# Groq AI API (get key from https://console.groq.com)
# ============================================================================
GROQ_API_KEY=your_groq_key_here

# ============================================================================
# Telegram (уведомления и боты)
# ============================================================================
# Токены ботов (префикс TELEGRAM_TOKEN_ автоматически собирает все токены)
TELEGRAM_TOKEN_VALSTANBOT=your_bot_token_here
TELEGRAM_TOKEN_AFONYA=your_bot_token_here

# Chat ID для алертов (получить через @userinfobot в Telegram)
TELEGRAM_ALERT_CHAT_ID=your_chat_id_here

# ============================================================================
# MongoDB (опционально, для миграции из old_postopus)
# ============================================================================
# MONGO_CLIENT=mongodb://localhost:27017

# ============================================================================
# Server
# ============================================================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=WARNING
# LOG_LEVEL=DEBUG   # для разработки
# LOG_LEVEL=INFO    # для прода

# ============================================================================
# Production Workflow (JSON)
# ============================================================================
PRODUCTION_WORKFLOW_CONFIG={"max_posts_per_regions":100,"max_digest_posts":5,"work_hours_start":7,"work_hours_end":22,"publish_mode":"test","region_pause_seconds":150}

# ============================================================================
# VK Production Groups (JSON маппинг region_code -> group_id)
# ============================================================================
VK_PRODUCTION_GROUPS={"mi":-123456789,"vp":-987654321}

# ============================================================================
# Test Polygon (опционально)
# ============================================================================
VK_TEST_GROUP_ID=-137760500
